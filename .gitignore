# --- 📦 依赖包 (体积巨大，必须忽略) ---
node_modules/

# --- 🏗️ 前端构建输出 ---
dist/
dist-ssr/
*.local

# --- 🦀 Tauri/Rust 后端核心 (最重要部分) ---
# Rust 的编译产物，体积极大，包含大量二进制文件
src-tauri/target/
# Tauri v2 生成的移动端/Schema 缓存文件
src-tauri/gen/
# 以前版本的构建输出（以防万一）
src-tauri/bin/

# --- 🔧 IDE 与 编辑器配置 ---
.vscode/
.idea/
*.suo
*.ntvs
*.njsproj
*.sln
*.sw?

# --- 🖥️ 操作系统生成的垃圾文件 ---
.DS_Store
Thumbs.db
Desktop.ini

# --- 🔐 环境变量与密钥 (安全防范) ---
.env
.env.local
.env.*.local

# --- 📝 日志文件 ---
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log
image.png

# --- 🛠️ 本地开发脚本 ---
scripts/bump-version.js
